# Copy to .env and fill in. Without AI keys the app runs in mock mode
# (deterministic offline enrichment) so you can demo it with zero setup.

# --- AI providers (leave blank to force mock mode) ---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_MODEL=sonar

# --- Storage (SQLite by default; swap for Postgres in prod) ---
DATABASE_URL=sqlite:///./cosailor.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/cosailor

# --- Target market ---
TARGET_ZIP=10013
SEARCH_RADIUS_MILES=25

# --- Pipeline tuning ---
ENRICH_CONCURRENCY=5
ENRICH_MAX_ATTEMPTS=3

# Force offline/mock mode even if keys are present (useful for demos/tests):
# MOCK_MODE=true
